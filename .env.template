# =============================================================
# Pincher — Level-2 Agent Environment Contract
# =============================================================
# Copy this to .env, fill in your keys, and run:
#   source .env && ./install.sh
# =============================================================

# Required
AGENT_NAME=pincher-agent
AGENT_ROLE=fleet-runtime-node

# GitHub — for registry pushes/downloads
GITHUB_TOKEN=

# AI providers (at least one required for LLM features)
DEEPINFRA_API_KEY=
DEEPINFRA_API_URL=https://api.deepinfra.com/v1
HEALER_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional — for OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_API_URL=

# Fleet membership
FLEET_HOMESERVER=
FLEET_MATRIX_USER=
FLEET_MATRIX_PASSWORD=
I2I_VESSEL=/tmp/i2i-vessel

# Resource limits (override defaults)
PINCHER_RAM_LIMIT_MB=1024
PINCHER_CPU_LIMIT_PERCENT=80
PINCHER_LOG_LEVEL=info
